# ──────────────────────────────────────────────
# StarGazer — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Google Cloud / Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
MODEL=gemini-2.0-flash

# OpenWeatherMap (free at openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_key

# Google Maps API Key (from Cloud Console → APIs → Credentials)
MAPS_API_KEY=your_maps_api_key

# N2YO Satellite Tracking (free at n2yo.com — 300 req/hour)
# Provides accurate ISS visual pass predictions with direction and magnitude
N2YO_API_KEY=your_n2yo_api_key

# NASA API (free at api.nasa.gov — DEMO_KEY works but is rate-limited)
# Used for APOD (Astronomy Picture of Day) and NeoWs (Near-Earth Objects)
NASA_API_KEY=DEMO_KEY

# Google Calendar OAuth (optional — app works without these)
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_CALENDAR_REFRESH_TOKEN=your_refresh_token
CALENDAR_ID=your_email@gmail.com
